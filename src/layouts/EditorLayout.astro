---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import TopBar from '../components/layout/TopBar.astro';
import BottomBar from '../components/layout/BottomBar.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import LineNumbers from '../components/layout/LineNumbers.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  filename?: string;
  filetype?: string;
}

const { 
  title, 
  description = 'Luis Ramírez - Backend Developer Portfolio', 
  image = '/og-image.png',
  filename, 
  filetype 
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Luis Ramírez" />
    <link rel="canonical" href={canonicalUrl.href} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="MrTanuk" />
    <meta property="og:locale" content="en_US" />
    
    <!-- PWA / Mobile -->
    <meta name="theme-color" content="#1e1e2e" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    
    <ClientRouter />
  </head>
  <body class="h-dvh flex flex-col overflow-hidden">
    <!-- Top Status Bar -->
    <TopBar filename={filename} filetype={filetype} />

    <!-- Main Editor Area -->
    <div class="flex flex-1 overflow-hidden min-h-0">
      <!-- Sidebar - NvimTree -->
      <Sidebar />

      <!-- Editor Content Area -->
      <main class="flex-1 flex overflow-hidden min-w-0">
        <!-- Line Numbers (hidden on mobile) -->
        <div class="hidden md:block">
          <LineNumbers />
        </div>

        <!-- Content -->
        <div id="content-scroll" class="flex-1 overflow-y-auto bg-(--ctp-crust) overscroll-contain">
          <article class="p-4 leading-6">
            <slot />
          </article>
        </div>
      </main>
    </div>

    <!-- Bottom Status Bar -->
    <BottomBar filename={filename} filetype={filetype} />
  </body>
</html>
