---
import { formatDateRange, calculateDuration } from '../../lib/utils.ts';

interface Props {
  company: string;
  role: string;
  location: string;
  startDate: string;
  endDate: string | null;
  description: readonly string[];
  technologies: readonly string[];
  url: string;
  isLast?: boolean;
}

const { 
  company, 
  role, 
  location, 
  startDate, 
  endDate, 
  description, 
  technologies,
  url,
  isLast = false 
} = Astro.props;

const dateRange = formatDateRange(startDate, endDate);
const duration = calculateDuration(startDate, endDate);
---

<article class="experience-card relative pl-6 pb-8">
  <!-- Timeline line -->
  <div class={`absolute left-0 top-2 bottom-0 w-px ${isLast ? 'h-8' : 'h-full'} bg-(--ctp-surface1)`}></div>
  
  <!-- Timeline dot -->
  <div class="absolute -left-1 top-2 w-2 h-2 rounded-full bg-(--ctp-mauve)"></div>
  
  <!-- Content -->
  <div class="bg-(--ctp-surface0) rounded-lg p-4 ml-2 hover:bg-(--ctp-surface1) transition-colors">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 sm:gap-2 mb-2">
      <div>
        <h3 class="text-lg font-bold text-(--ctp-text)">
          {role}
          <span class="text-(--ctp-subtext0)"> at </span>
          {url ? (
            <a 
              href={url} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="text-(--ctp-blue) hover:underline hover:text-(--ctp-sapphire) transition-colors"
            >
              {company} <span class="nf text-xs">&#xf08e;</span>
            </a>
          ) : (
            <span class="text-(--ctp-blue)">{company}</span>
          )}
        </h3>
      </div>
      
      <!-- Date Container: Left align on mobile, Right align on desktop -->
      <div class="text-left sm:text-right text-sm text-(--ctp-subtext0)">
        <p>{dateRange}</p>
        <p class="text-(--ctp-mauve)">{duration}</p>
      </div>
    </div>
    
    <!-- Location -->
    <div class="flex items-center gap-1 text-xs text-(--ctp-subtext0) mb-3">
      <span class="nf">&#xeb29;</span>
      <span>{location}</span>
    </div>
    
    <!-- Description -->
    <ul class="space-y-1 mb-3">
      {description.map((item) => (
        <li class="flex items-start gap-2 text-sm text-(--ctp-subtext1)">
          <span class="nf text-(--ctp-green) mt-0.5">&#xeab2;</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
    
    <!-- Technologies -->
    <div class="flex flex-wrap gap-1">
      {technologies.map((tech) => (
        <span class="px-2 py-0.5 text-xs bg-(--ctp-mantle) text-(--ctp-teal) rounded">
          {tech}
        </span>
      ))}
    </div>
  </div>
</article>
