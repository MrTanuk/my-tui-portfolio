---
import SectionHeader from '../ui/SectionHeader.astro';
import ProjectCard from '../ui/ProjectCard.astro';
import { 
  fetchGitHubRepos, 
  getFeaturedRepos, 
  getUniqueLanguages 
} from '../../lib/github';
import { CONFIG } from '../../config';

// Fetch repos at build time
const allRepos = await fetchGitHubRepos();
const featuredRepos = getFeaturedRepos(allRepos, CONFIG.FEATURED_REPOS_COUNT);
const languages = getUniqueLanguages(allRepos);
---

<section id="projects" class="mb-16">
  <!-- Comment -->
  <SectionHeader comment="Projects" title="Featured Projects" />
  
  <!-- Language filters -->
  <div class="flex flex-wrap gap-2 mb-6" id="project-filters">
    <button 
      class="filter-btn active px-3 py-1 text-sm rounded-full bg-(--ctp-mauve) text-(--ctp-crust) transition-colors"
      data-language="all"
    >
      All
    </button>
    {languages.map((lang) => (
      <button 
        class="filter-btn px-3 py-1 text-sm rounded-full bg-(--ctp-surface0) text-(--ctp-text) hover:bg-[var(--ctp-surface1) transition-colors"
        data-language={lang}
      >
        {lang}
      </button>
    ))}
  </div>
  
  <!-- Projects grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="projects-grid">
    {featuredRepos.map((repo) => (
      <div class="project-item" data-language={repo.language || 'Unknown'}>
        <ProjectCard 
          name={repo.name}
          description={repo.description}
          url={repo.html_url}
          homepage={repo.homepage}
          language={repo.language}
          stars={repo.stargazers_count}
          forks={repo.forks_count}
          updatedAt={repo.updated_at}
          topics={repo.topics}
        />
      </div>
    ))}
  </div>
  
  <!-- Empty state (hidden by default) -->
  <div id="no-projects" class="hidden text-center py-8 text-(--ctp-subtext0)">
    <span class="nf text-4xl text-(--ctp-overlay0)">&#xeaa2;</span>
    <p class="mt-2">No projects found for this filter</p>
  </div>
  
  <!-- Link to all projects -->
  <div class="mt-6 text-center">
    <a 
      href="/projects" 
      class="inline-flex items-center gap-2 text-(--ctp-blue) hover:text-(--ctp-lavender) transition-colors"
    >
      <span>View all projects</span>
      <span class="nf">&#xeab6;</span>
    </a>
  </div>
</section>

<script>
  import { initProjectFilters } from '../../lib/utils';
  
  document.addEventListener('DOMContentLoaded', initProjectFilters);
  document.addEventListener('astro:page-load', initProjectFilters);
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
