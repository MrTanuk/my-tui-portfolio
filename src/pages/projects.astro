---
import EditorLayout from '../layouts/EditorLayout.astro';
import ProjectCard from '../components/ui/ProjectCard.astro';
import { 
  fetchGitHubRepos, 
  getUniqueLanguages,
  getLanguageInfo 
} from '../lib/github';
import { CONFIG } from '../config';

const allRepos = await fetchGitHubRepos();
const languages = getUniqueLanguages(allRepos);
---

<EditorLayout 
  title="MrTanuk | Projects"
  description="GitHub repositories by Luis Ramírez. Featured and public projects built with PHP, TypeScript, C++, Python, and more."
  filename="projects.astro" 
  filetype="Astro"
>
  <!-- Back button -->
  <div class="mb-6">
    <a 
      href="/"
      class="inline-flex items-center gap-2 px-3 py-1.5 bg-(--ctp-surface0) text-(--ctp-text) rounded-lg hover:bg-(--ctp-surface1) transition-colors text-sm"
    >
      <span class="nf">&#xeab4;</span>
      <span>Back to portfolio</span>
    </a>
  </div>

  <!-- Header -->
  <section class="mb-8">
    <div class="text-(--ctp-overlay0) text-sm mb-2 select-none">
      {'//'} All Projects
    </div>
    <h1 class="text-2xl md:text-3xl font-bold text-(--ctp-mauve) mb-2">
      GitHub Repositories
    </h1>
    <p class="text-(--ctp-subtext0)">
      All public repositories from <a 
        href={CONFIG.PERSONAL.GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="text-(--ctp-blue) hover:text-(--ctp-lavender) transition-colors"
      >
        github.com/{CONFIG.GITHUB_USERNAME}
      </a>
    </p>
  </section>

  <!-- Filters -->
  <section class="mb-6">
    <div class="flex flex-wrap items-center gap-2 mb-4">
      <span class="text-sm text-(--ctp-subtext0)">Filter:</span>
      <button 
        class="filter-btn active px-3 py-1 text-sm rounded-full bg-(--ctp-mauve) text-(--ctp-crust) transition-colors"
        data-language="all"
      >
        All ({allRepos.length})
      </button>
        {languages.map((lang) => {
          const count = allRepos.filter(r => r.language === lang).length;
          const info = getLanguageInfo(lang);
          
          return (
            <button 
              class="filter-btn px-3 py-1 text-sm rounded-full bg-(--ctp-surface0) text-(--ctp-text) hover:bg-(--ctp-surface1) transition-colors flex items-center gap-1.5"
              data-language={lang}
            >
              <span 
                class="w-2 h-2 rounded-full"
                style={`background-color: ${info.color}`}
              ></span>
              {lang} ({count})
            </button>
          );
        })}
    </div>
    
    <!-- Results count -->
    <p id="results-count" class="text-sm text-(--ctp-subtext0)">
      Showing {allRepos.length} repositories
    </p>
  </section>

  <!-- Projects Grid -->
  <section id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
    {allRepos.map((repo) => (
      <div 
        class="project-item" 
        data-language={repo.language || 'Unknown'}
      >
        <ProjectCard 
          name={repo.name}
          description={repo.description}
          url={repo.html_url}
          homepage={repo.homepage}
          language={repo.language}
          stars={repo.stargazers_count}
          forks={repo.forks_count}
          updatedAt={repo.updated_at}
          topics={repo.topics}
        />
      </div>
    ))}
  </section>

  <!-- Empty state -->
  <div id="no-projects" class="hidden text-center py-12">
    <span class="nf text-5xl text-(--ctp-overlay0)">&#xeaa2;</span>
    <p class="mt-4 text-(--ctp-subtext0)">No repositories found</p>
    <p class="text-sm text-(--ctp-overlay0)">Try a different filter</p>
  </div>
</EditorLayout>

<script>
  import { initProjectFilters } from '../lib/utils.ts';
  
  document.addEventListener('DOMContentLoaded', initProjectFilters);
  document.addEventListener('astro:page-load', initProjectFilters);
</script>
